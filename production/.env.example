# =============================================================================
# .env.example — Copy to .env and fill in real values
# NEVER commit .env to version control
# =============================================================================

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_strong_password
MONGO_DB=crowd_detection

# ── Flask ───────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=changeme_32_char_random_secret

# ── Detection ───────────────────────────────────────────────────────────────
CAMERA_INDEX=0
ALERT_THRESHOLD=10
PUBLISH_INTERVAL=30
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.40

# ── ML Service ──────────────────────────────────────────────────────────────
SEQ_LEN=20
